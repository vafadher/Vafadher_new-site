  <!-- FEATURED NOTE -->
  <section style="border-bottom: 1px solid var(--b-dim); background: var(--surf-1);">
    <div style="max-width: var(--max); margin: 0 auto; padding: 80px var(--px);" data-reveal>
      <span class="tag-label">Featured note</span>
